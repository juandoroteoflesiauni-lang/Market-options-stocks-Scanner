# ============================================================
# TRADING TERMINAL — TEMPLATE DE VARIABLES DE ENTORNO
#
# INSTRUCCIONES:
# 1. Copiar este archivo: cp .env.example .env
# 2. Completar TODOS los campos marcados con COMPLETAR
# 3. NUNCA commitear el archivo .env (está en .gitignore)
# 4. Generar SECRET_KEY con: openssl rand -hex 32
# ============================================================

# ── ENTORNO ──────────────────────────────────────────────
# development → usa testnet, logs verbose, debug activo
# staging     → usa testnet, logs normales
# production  → usa mainnet con DINERO REAL
ENVIRONMENT=development
DEBUG=true

# ── BASE DE DATOS ────────────────────────────────────────
# Para desarrollo local con Docker:
DATABASE_URL=postgresql+asyncpg://trading_user:dev_password_cambiar@localhost:5432/trading_db
POSTGRES_DB=trading_db
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=dev_password_cambiar  # ← CAMBIAR en producción

# ── REDIS ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=                      # ← Descomentar y completar en producción

# ── SEGURIDAD JWT ────────────────────────────────────────
# GENERAR CON: openssl rand -hex 32
SECRET_KEY=COMPLETAR_CON_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ── CORSALLOWED ORIGINS ──────────────────────────────────
# Separados por coma. En producción, solo el dominio real.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── APLICACIÓN ───────────────────────────────────────────
APP_NAME=Trading Terminal Pro
APP_VERSION=0.1.0

# ── BINANCE ──────────────────────────────────────────────
# IMPORTANTE: En ENVIRONMENT=development se usa automáticamente Testnet
# Testnet: https://testnet.binance.vision/ (obtener keys gratis)
# Mainnet: https://www.binance.com/es/my/settings/api-management
BINANCE_API_KEY=COMPLETAR
BINANCE_API_SECRET=COMPLETAR

# ── MT5/MT4 (FOREX) ──────────────────────────────────────
# Descomentar si vas a usar MetaTrader 5
# MT5_LOGIN=COMPLETAR
# MT5_PASSWORD=COMPLETAR
# MT5_SERVER=COMPLETAR

# ── GESTIÓN DE RIESGO ────────────────────────────────────
# Estos valores protegen tu dinero. Ajustar según tu tolerancia al riesgo.
MAX_ORDER_VALUE_USD=10000
MIN_ORDER_VALUE_USD=10
MAX_DAILY_VOLUME_USD=50000
MAX_POSITION_SIZE_PCT=0.25

# ── OPENCODE (CLI local) ─────────────────────────────────
# Usado por opencode.json → provider.tokenrouter.options.apiKey
TOKENROUTER_API_KEY=COMPLETAR

# ── LOGGING ──────────────────────────────────────────────
LOG_LEVEL=INFO
# En production: JSON logs. En development: colorized logs.

# ── FRONTEND (Variables para Vite/React) ─────────────────
# Estas variables deben empezar con VITE_ para ser accesibles en el frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=Trading Terminal Pro
VITE_ENVIRONMENT=development
