# ============================================================
# TRADING TERMINAL — TEMPLATE DE VARIABLES DE ENTORNO
#
# INSTRUCCIONES:
# 1. Copiar este archivo: cp .env.example .env
# 2. Completar TODOS los campos marcados con COMPLETAR
# 3. NUNCA commitear el archivo .env (está en .gitignore)
# 4. Generar SECRET_KEY con: openssl rand -hex 32
# ============================================================

# ── ENTORNO ──────────────────────────────────────────────
# development → usa testnet, logs verbose, debug activo
# staging     → usa testnet, logs normales
# production  → usa mainnet con DINERO REAL
ENVIRONMENT=development
DEBUG=true

# ── BASE DE DATOS ────────────────────────────────────────
# Para desarrollo local con Docker:
DATABASE_URL=postgresql+asyncpg://trading_user:dev_password_cambiar@localhost:5432/trading_db
POSTGRES_DB=trading_db
POSTGRES_USER=trading_user
POSTGRES_PASSWORD=dev_password_cambiar  # ← CAMBIAR en producción

# ── REDIS ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
# REDIS_PASSWORD=                      # ← Descomentar y completar en producción

# ── SEGURIDAD JWT ────────────────────────────────────────
# GENERAR CON: openssl rand -hex 32
SECRET_KEY=COMPLETAR_CON_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ── CORSALLOWED ORIGINS ──────────────────────────────────
# Separados por coma. En producción, solo el dominio real.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── APLICACIÓN ───────────────────────────────────────────
APP_NAME=Trading Terminal Pro
APP_VERSION=0.1.0

# ── BINANCE ──────────────────────────────────────────────
# IMPORTANTE: En ENVIRONMENT=development se usa automáticamente Testnet
# Testnet: https://testnet.binance.vision/ (obtener keys gratis)
# Mainnet: https://www.binance.com/es/my/settings/api-management
BINANCE_API_KEY=COMPLETAR
BINANCE_API_SECRET=COMPLETAR

# ── PROVEEDORES DE DATOS DE MERCADO ─────────────────────
FMP_API_KEY=COMPLETAR
MASSIVE_API_KEY=COMPLETAR
MASSIVE_WS_URL=COMPLETAR
POLYGON_API_KEY=COMPLETAR
FINNHUB_API_KEY=COMPLETAR
TIINGO_API_KEY=COMPLETAR

# ── ALPACA (EQUITY + OPTIONS PAPER/LIVE) ─────────────────
ALPACA_API_KEY=COMPLETAR
ALPACA_API_SECRET=COMPLETAR
ALPACA_SECRET_KEY=COMPLETAR
ALPACA_TRADING_MODE=paper
ALPACA_PAPER_TRADING=true
ALPACA_TRADING_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_BASE_URL=https://data.alpaca.markets
ALPACA_EOD_FLATTEN_ENABLED=true
ALPACA_EOD_FLATTEN_START_ET=15:45

# ── BINGX (CRYPTO BOT) ───────────────────────────────────
BINGX_API_KEY=COMPLETAR
BINGX_SECRET=COMPLETAR
BINGX_BOT_PAPER_TRADING=true
BINGX_BOT_ENABLE_LIVE=false

# ── IA / LLM (GEMINI) ────────────────────────────────────
# NUNCA hardcodear en código. Rotar si alguna vez se expuso.
GEMINI_API_KEY=COMPLETAR
# GEMINI_API_KEY_1=COMPLETAR
# GEMINI_API_KEY_2=COMPLETAR

# ── AGENTIC FUNNEL (opcional) ─────────────────────────────
# auto | always | off — gate del comité de ejecución LLM
AI_AGENTIC_COMMITTEE_MODE=auto
AI_AGENTIC_COMMITTEE_MIN_SIGNAL=0.65
# true → en degradación del comité, fallback a quant puro (EXECUTE)
AI_AGENTIC_QUANT_FALLBACK=false
AGENTIC_LLM_TIMEOUT_S=3.0

# ── LLM PROVIDER ROUTER (Enterprise AI) ───────────────────
# Comma-separated fallback priority when primary provider fails
LLM_PROVIDER_PRIORITY=github_models,gemini,azure_openai,claude,groq
ANTHROPIC_API_KEY=
GROQ_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514
GROQ_MODEL=llama-3.3-70b-versatile

# ── AUDITORÍA Y ML LOCAL ─────────────────────────────────
AUDIT_DB_PATH=data/audit_complex.duckdb

# ── OPERATOR AUTH (SHELL WEB) ────────────────────────────
# Generar QA_SESSION_SECRET: openssl rand -hex 32
# Generar password hash: echo -n "tu_password" | sha256sum
QA_SESSION_SECRET=COMPLETAR_CON_openssl_rand_hex_32
QA_APP_USERNAME=admin
QA_APP_PASSWORD_HASH=sha256:COMPLETAR_HASH_HEX
QA_APP_DISPLAY_NAME=Operator

# ── NOTIFICACIONES (OPCIONAL) ────────────────────────────
# TELEGRAM_BOT_TOKEN=COMPLETAR
# TELEGRAM_CHAT_ID=COMPLETAR

# ── MT5/MT4 (FOREX) ──────────────────────────────────────
# Descomentar si vas a usar MetaTrader 5
# MT5_LOGIN=COMPLETAR
# MT5_PASSWORD=COMPLETAR
# MT5_SERVER=COMPLETAR

# ── GESTIÓN DE RIESGO ────────────────────────────────────
# Estos valores protegen tu dinero. Ajustar según tu tolerancia al riesgo.
MAX_ORDER_VALUE_USD=10000
MIN_ORDER_VALUE_USD=10
MAX_DAILY_VOLUME_USD=50000
MAX_POSITION_SIZE_PCT=0.25

# ── OPENCODE (CLI local) ─────────────────────────────────
# Usado por opencode.json → provider.tokenrouter.options.apiKey
TOKENROUTER_API_KEY=COMPLETAR

# ── LOGGING ──────────────────────────────────────────────
LOG_LEVEL=INFO
# En production: JSON logs. En development: colorized logs.

# ── FRONTEND (Variables para Vite/React) ─────────────────
# Estas variables deben empezar con VITE_ para ser accesibles en el frontend
VITE_API_BASE_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_APP_NAME=Trading Terminal Pro
VITE_ENVIRONMENT=development

# ── MÓDULO 05 FUNDING THRESHOLDS ─────────────────────────
QA_FTMO_PROFILE_ID=ftmo_2_step_standard
QA_FTMO_INITIAL_CAPITAL=100000.0
QA_FTMO_DAILY_LOSS_LIMIT_PCT=5.0
QA_FTMO_MAX_LOSS_LIMIT_PCT=10.0
QA_FTMO_BASE_RISK_PER_TRADE_PCT=0.50

QA_PA_MIN_EXPECTANCY_R=0.20
QA_PA_MIN_PROFIT_FACTOR=1.6
QA_PA_MIN_SHARPE=1.5
QA_PA_MIN_SORTINO=2.0
QA_PA_MIN_CALMAR=2.0
QA_PA_MAX_BUR=0.60
QA_PA_MAX_ULCER_INDEX=2.0
QA_PA_MAX_CVAR99_VS_DLL=0.60
QA_PA_MAX_RISK_OF_RUIN_PCT=0.001

QA_SIZING_KELLY_BASE_FRACTION=0.25
QA_SIZING_KELLY_CAP=0.25

# ── MFFU BUILDER PLAN ($50K) ─────────────────────────────
QA_BUILDER_PROFILE_ID=MFFU_BUILDER_50K
QA_BUILDER_STARTING_BALANCE=50000
QA_BUILDER_PROFIT_TARGET=3000
QA_BUILDER_DAILY_LOSS_AMOUNT=1000
QA_BUILDER_MAX_LOSS_AMOUNT=2000
QA_BUILDER_PAYOUT_BUFFER=2100
QA_BUILDER_USE_ADDON_DD=false
QA_BUILDER_BASE_RISK_PER_TRADE_PCT=0.50
QA_BUILDER_MAX_MINIS=4
QA_BUILDER_MAX_MICROS=40
