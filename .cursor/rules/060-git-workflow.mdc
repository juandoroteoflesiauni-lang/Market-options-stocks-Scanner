venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.coverage
htmlcov/

# === NODE / FRONTEND ===
node_modules/
dist/
.next/
.nuxt/
*.local

# === BASES DE DATOS LOCALES ===
*.sqlite
*.db
*.db-journal

# === IDEs ===
.idea/
