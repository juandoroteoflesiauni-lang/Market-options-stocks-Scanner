## 💰 VALIDACIONES FINANCIERAS CRÍTICAS

```python
# services/risk_service.py

class RiskService:
    """Todas las validaciones de riesgo antes de ejecutar órdenes."""

    MAX_ORDER_VALUE_USD = Decimal("10000")
    MAX_DAILY_VOLUME_USD = Decimal("50000")
    MAX_POSITION_SIZE_PCT = Decimal("0.25")  # 25% del portfolio

    async def validate_order(
        self,
        order: OrderCreate,
        user_portfolio: Portfolio,
        current_price: Decimal
    ) -> None:
        """
        Valida riesgo ANTES de enviar orden al exchange.
        Lanza RiskViolationError si alguna regla se incumple.
        """
        order_value = order.quantity * current_price

        # 1. Límite por orden
        if order_value > self.MAX_ORDER_VALUE_USD:
            raise RiskViolationError(
                f"Orden ${order_value:.2f} excede límite de ${self.MAX_ORDER_VALUE_USD}"
            )

        # 2. Verificar fondos disponibles
        if order.side == "BUY":
            if user_portfolio.available_usd < order_value:
                raise InsufficientFundsError(
                    f"Fondos disponibles ${user_portfolio.available_usd:.2f} < ${order_value:.2f}"
                )

        # 3. Tamaño máximo de posición
        position_pct = order_value / user_portfolio.total_value
        if position_pct > self.MAX_POSITION_SIZE_PCT:
            raise RiskViolationError(
                f"Posición {position_pct:.1%} excede máximo {self.MAX_POSITION_SIZE_PCT:.1%}"
            )

        # 4. Volumen diario
        daily_volume = await self._get_daily_volume(order.user_id)
        if daily_volume + order_value > self.MAX_DAILY_VOLUME_USD:
            raise RiskViolationError("Límite de volumen diario alcanzado")
```

