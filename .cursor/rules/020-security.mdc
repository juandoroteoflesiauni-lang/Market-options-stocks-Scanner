## ✅ VALIDACIÓN DE INPUTS — Prevenir inyecciones

```python
# schemas/order_schema.py
from pydantic import BaseModel, validator, Field
from decimal import Decimal
from typing import Literal

class OrderCreate(BaseModel):
    symbol: str = Field(..., regex=r'^[A-Z]{2,10}USDT?$', example="BTCUSDT")
    side: Literal["BUY", "SELL"]
    order_type: Literal["MARKET", "LIMIT", "STOP_LIMIT"]
    quantity: Decimal = Field(..., gt=0, le=1000000)
    price: Optional[Decimal] = Field(None, gt=0)

    @validator('quantity')
    def validate_quantity_precision(cls, v):
        # Máximo 8 decimales para crypto
        if abs(v.as_tuple().exponent) > 8:
            raise ValueError('Máximo 8 decimales en quantity')
        return v

    @validator('price', always=True)
    def price_required_for_limit(cls, v, values):
        if values.get('order_type') == 'LIMIT' and v is None:
            raise ValueError('Price requerido para órdenes LIMIT')
        return v
```

